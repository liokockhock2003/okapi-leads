########################################################################
# Okapi Leads — manual API requests (VS Code REST Client / JetBrains HTTP)
#
# Demo leads are ingested through the REAL endpoint, so each one flows through
# validation -> qualification -> persist, exactly like production traffic.
#
# Requires BOTH running:
#   php artisan serve
#   php artisan queue:work
# (ingestion is async — the 202 returns instantly, the lead persists in the job)
#
# `status` is intentionally omitted — LeadQualificationService resolves it.
# Expected spread: 6 qualified · 4 under_review · 5 disqualified.
########################################################################

@host = http://127.0.0.1:8000

### Qualified — RM350, landed, tile, Selangor
POST {{host}}/api/leads
Content-Type: application/json
Accept: application/json

{
  "customer_name": "Ahmad bin Ismail",
  "email": "ahmad.ismail@example.com",
  "phone": "012-3456789",
  "monthly_bill_rm": 350,
  "property_type": "landed",
  "roof_type": "tile",
  "state": "Selangor"
}

